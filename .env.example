APP_NAME="SMS Gateway Manager"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

APP_LOCALE=pt
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_PT

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Base de dados — MySQL (preenche com as credenciais do teu MySQL remoto)
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sms_gateway
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ---------------------------------------------------------------------------
# Filas — usa "database" (default) ou "redis" em produção
# ---------------------------------------------------------------------------
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@smsgateway.local"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# httpSMS — https://docs.httpsms.com
# A API Key e o número podem também ser geridos na página de Configurações.
# Estes valores servem de fallback / bootstrap inicial.
# ---------------------------------------------------------------------------
HTTPSMS_BASE_URL=https://api.httpsms.com/v1
HTTPSMS_API_KEY=
HTTPSMS_DEFAULT_FROM=
# Segredo partilhado usado para validar os webhooks recebidos do httpSMS
HTTPSMS_WEBHOOK_SECRET=

VITE_APP_NAME="${APP_NAME}"
